# Supabase PostgreSQL connection string
# Get this from: Supabase Dashboard > Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase Auth / client (required by @supabase/ssr in proxy.ts and lib/supabase/*)
NEXT_PUBLIC_SUPABASE_URL=https://[YOUR-PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service-role key — required only for DELETE /api/users (GDPR right to erasure).
# NEVER expose this to the client. Get it from Dashboard > Project Settings > API > service_role.
SUPABASE_SERVICE_ROLE_KEY=

# Public site URL — used by app/robots.ts, app/sitemap.ts and metadata canonical/OG.
# Example: https://tenplanner.app
NEXT_PUBLIC_SITE_URL=

# Upstash Redis (optional) — enables distributed rate-limiting across Vercel containers.
# When both are set, lib/rate-limit.ts uses Upstash; otherwise falls back to in-memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Vercel AI Gateway (preferred) — used by /api/dr-planner
# On Vercel the SDK picks up OIDC automatically. Locally, pull the key with `vercel env pull`.
AI_GATEWAY_API_KEY=

# Anthropic API key (only needed if you bypass the Gateway and use @ai-sdk/anthropic directly)
NEXT_ANTHROPIC_API_KEY=

# Pexels API key used by /api/stock-images (optional — route returns 503 without it)
PEXELS_API_KEY=

# Dev-only: comma-separated list of origins allowed by the Next dev server
# e.g. "10.131.105.5,192.168.1.20"
NEXT_DEV_ALLOWED_ORIGINS=

# Cron secret — protege /api/cron/cleanup. Vercel lo inyecta automáticamente al cron.
# Genera uno con: openssl rand -hex 32
CRON_SECRET=

# Datos legales del cliente — usados en /privacidad y /aviso-legal
# Configúralos en Vercel Project Settings → Environment Variables
NEXT_PUBLIC_LEGAL_COMPANY_NAME=
NEXT_PUBLIC_LEGAL_NIF=
NEXT_PUBLIC_LEGAL_ADDRESS=
NEXT_PUBLIC_LEGAL_PRIVACY_EMAIL=
NEXT_PUBLIC_LEGAL_CONTACT_EMAIL=
NEXT_PUBLIC_LEGAL_DPO=
NEXT_PUBLIC_LEGAL_MERCANTILE_REGISTRY=
